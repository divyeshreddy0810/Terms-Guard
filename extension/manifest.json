{
  "manifest_version": 3,
  "name": "TermsGuard AI",
  "version": "1.0",
  "description": "Real-time T&C ethical analysis using RAG and LLM",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "TermsGuard AI"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}